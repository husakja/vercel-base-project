# ---------------------------------------------------------------------------
# Site
# ---------------------------------------------------------------------------
# The canonical public URL of your site (used for absolute URLs / OG tags)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# ---------------------------------------------------------------------------
# Database (Vercel Postgres / Neon)
# ---------------------------------------------------------------------------
# Pooled connection — used by Prisma at runtime
DATABASE_URL=postgres://default:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require
# Direct (non-pooled) connection — used by Prisma migrations
DATABASE_URL_UNPOOLED=postgres://default:password@host.region.aws.neon.tech/dbname?sslmode=require

# ---------------------------------------------------------------------------
# NextAuth.js
# ---------------------------------------------------------------------------
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=your-nextauth-secret-here
# The canonical URL of your app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# OAuth providers (optional — remove if unused)
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here
