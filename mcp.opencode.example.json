{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "environment": {
        "NEXT_TELEMETRY_DISABLED": "{env:NEXT_TELEMETRY_DISABLED}"
      },
      "enabled": true
    },
    "vercel": {
      "type": "local",
      "command": ["npx", "-y", "@mistertk/vercel-mcp"],
      "environment": {
        "VERCEL_API_KEY": "{env:VERCEL_API_KEY}"
      },
      "enabled": true
    },
    "tailwind": {
      "type": "local",
      "command": ["npx", "-y", "@iflow-mcp/coppinaphil-tailwind-mcp-server"],
      "enabled": true
    },
    "docker": {
      "type": "local",
      "command": ["npx", "-y", "@hypnosis/docker-mcp-server"],
      "environment": {
        "DOCKER_MCP_AUTO_DISCOVER": "{env:DOCKER_MCP_AUTO_DISCOVER}",
        "DOCKER_MCP_MASK_SECRETS": "{env:DOCKER_MCP_MASK_SECRETS}",
        "DOCKER_MCP_PROFILES_FILE": "{env:DOCKER_MCP_PROFILES_FILE}"
      },
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "{env:MCP_POSTGRES_URL}"
      ],
      "enabled": true
    }
  }
}
